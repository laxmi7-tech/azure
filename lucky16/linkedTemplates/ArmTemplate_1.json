										},
										"sink": {
											"name": "UsageDate",
											"type": "String",
											"physicalType": "varchar"
										}
									},
									{
										"source": {
											"name": "CostUSD",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "CostUSD",
											"type": "Double",
											"physicalType": "float"
										}
									},
									{
										"source": {
											"name": "Cost",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "Cost",
											"type": "Double",
											"physicalType": "float"
										}
									},
									{
										"source": {
											"name": "ForecastCost",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "ForecastCost",
											"type": "Double",
											"physicalType": "float"
										}
									},
									{
										"source": {
											"name": "Currency",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "Currency",
											"type": "String",
											"physicalType": "varchar"
										}
									}
								],
								"typeConversion": true,
								"typeConversionSettings": {
									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "copydatatostage",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "AzureSqlTable1",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
